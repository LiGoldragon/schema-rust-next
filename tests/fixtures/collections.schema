((Register Cluster) (Observe Query))
((Projected (KeyValue [NodeName NodeConfig])) (Listed (Vec [NodeName])))
{
  NodeName [Text]
  NodeConfig [Text]
  Service [Text]
  Query [Topic]
  Topic [Text]
  Cluster [(services (Vec [Service])) (nodes (KeyValue [NodeName NodeConfig])) (cache (Option [NodeConfig]))]
}
