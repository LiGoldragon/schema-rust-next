[(Register Cluster) (Observe Query)]
[(Projected (Map NodeName NodeConfig)) (Listed (Vector NodeName))]
{
  NodeName String
  NodeConfig String
  Service String
  Query Topic
  Topic String
  Digest Bytes
  Fingerprint (Bytes 4)
  Cluster { (Services (Vector Service)) (Nodes (Map NodeName NodeConfig)) (Cache (Optional NodeConfig)) healthy.Boolean configPath.Path Digest Fingerprint }
}
