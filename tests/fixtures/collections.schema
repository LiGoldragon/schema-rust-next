((Register Cluster) (Observe Query))
((Projected (Map (NodeName NodeConfig))) (Listed (Vec NodeName)))
{
  NodeName {| NodeName string String |}
  NodeConfig {| NodeConfig string String |}
  Service {| Service string String |}
  Query {| Query topic Topic |}
  Topic {| Topic string String |}
  Cluster {| Cluster services (Vec Service) nodes (Map (NodeName NodeConfig)) cache (Optional NodeConfig) healthy Boolean configPath Path |}
}
