Input@[(Register Cluster) (Observe Query)]
Output@[(Projected (Map (NodeName NodeConfig))) (Listed (Vec NodeName))]
{
  NodeName@{ string@String }
  NodeConfig@{ string@String }
  Service@{ string@String }
  Query@{ topic@Topic }
  Topic@{ string@String }
  Cluster@{ services@(Vec Service) nodes@(Map (NodeName NodeConfig)) cache@(Optional NodeConfig) healthy@Boolean configPath@Path }
}
