[(Register Cluster) (Observe Query)]
[(Projected (Map NodeName NodeConfig)) (Listed (Vector NodeName))]
{
  NodeName String
  NodeConfig String
  Service String
  Query Topic
  Topic String
  Digest Bytes
  Fingerprint (Bytes 4)
  Cluster { services (Vector Service) nodes (Map NodeName NodeConfig) cache (Optional NodeConfig) healthy Boolean configPath Path digest Digest fingerprint Fingerprint }
}
