((SignalIn SignalRequest)
 (NexusIn NexusRequest)
 (SemaIn SemaRequest)
 (Admin AdminRequest)
 Heartbeat)
((SignalOut SignalReply)
 (NexusOut NexusReply)
 (SemaOut SemaReply)
 (AdminOut AdminReply)
 (Event RuntimeEvent)
 (Rejected Rejected))
{
  CommitSequence [Integer]
  DatabaseDigest [Integer]
  ActorIdentifier [Text]
  SocketPath [Text]
  SignalRequest ((RecordIntent RecordIntent) (ObserveIntent ObserveIntent) (SubscribeIntent SubscribeIntent))
  SignalReply ((RecordAccepted RecordAccepted) (ObservationReturned ObservationReturned) (SubscriptionStarted SubscriptionStarted))
  NexusRequest ((PushSignal PushSignal) (PushSemaResult PushSemaResult) ResolveMail ExpireMail)
  NexusReply ((PushedToSema PushedToSema) (MailResolved MailResolved) MailExpired)
  SemaRequest ((WriteEntry WriteEntry) (ReadEntries ReadEntries) (OpenSubscription OpenSubscription) (CloseSubscription CloseSubscription))
  SemaReply ((EntryWritten EntryWritten) (EntriesRead EntriesRead) (SubscriptionOpened SubscriptionOpened) (SubscriptionClosed SubscriptionClosed))
  AdminRequest (Drain Pause Resume (Snapshot Snapshot))
  AdminReply (Drained Paused Resumed (SnapshotReady SnapshotReady))
  RuntimeEvent ((MailSent MailSent) (MessageAccepted MessageAccepted) (MessageCommitted MessageCommitted) (MessageFailed MessageFailed))
  Rejected [RejectionReason]
  RejectionReason (Malformed Unauthorized Conflict Unsupported StaleVersion InternalError)
  RecordIntent [ActorIdentifier Entry]
  ObserveIntent [Query]
  SubscribeIntent [Query]
  RecordAccepted [RecordIdentifier CommitSequence]
  ObservationReturned [RecordSet]
  SubscriptionStarted [SubscriptionToken]
  PushSignal [SignalRequest]
  PushSemaResult [SemaReply]
  PushedToSema [SemaRequest]
  MailResolved [SignalReply]
  WriteEntry [Entry]
  ReadEntries [Query]
  OpenSubscription [Query]
  CloseSubscription [SubscriptionToken]
  EntryWritten [RecordIdentifier CommitSequence DatabaseDigest]
  EntriesRead [RecordSet DatabaseDigest]
  SubscriptionOpened [SubscriptionToken CommitSequence]
  SubscriptionClosed [SubscriptionToken CommitSequence]
  Snapshot [SocketPath]
  SnapshotReady [SocketPath DatabaseDigest]
  MailSent [SignalRequest]
  MessageAccepted [SignalRequest]
  MessageCommitted [CommitSequence]
  MessageFailed [RejectionReason]
  Entry [Topics Kind Description Magnitude ActorIdentifier]
  Topic [Text]
  Topics [[Topic]]
  Description [Text]
  Kind (Decision Principle Correction Clarification Constraint Observation Question)
  Magnitude (Minimum VeryLow Low Medium High VeryHigh Maximum)
  Query [Topics (kinds [Kind]) (limit (Optional Integer))]
  RecordIdentifier [Integer]
  SubscriptionToken [Integer]
  RecordSet [(records [Entry]) (byTopic {Topic RecordIdentifier})]
}
