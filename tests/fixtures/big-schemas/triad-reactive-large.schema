((SignalIn SignalRequest)
 (NexusIn NexusRequest)
 (SemaIn SemaRequest)
 (Admin AdminRequest)
 Heartbeat)
((SignalOut SignalReply)
 (NexusOut NexusReply)
 (SemaOut SemaReply)
 (AdminOut AdminReply)
 (Event RuntimeEvent)
 (Rejected Rejected))
{
  CommitSequence {| CommitSequence integer Integer |}
  DatabaseDigest {| DatabaseDigest integer Integer |}
  ActorIdentifier {| ActorIdentifier string String |}
  SocketPath {| SocketPath string String |}
  SignalRequest (| SignalRequest (RecordIntent RecordIntent) (ObserveIntent ObserveIntent) (SubscribeIntent SubscribeIntent) |)
  SignalReply (| SignalReply (RecordAccepted RecordAccepted) (ObservationReturned ObservationReturned) (SubscriptionStarted SubscriptionStarted) |)
  NexusRequest (| NexusRequest (PushSignal PushSignal) (PushSemaResult PushSemaResult) ResolveMail ExpireMail |)
  NexusReply (| NexusReply (PushedToSema PushedToSema) (MailResolved MailResolved) MailExpired |)
  SemaRequest (| SemaRequest (WriteEntry WriteEntry) (ReadEntries ReadEntries) (OpenSubscription OpenSubscription) (CloseSubscription CloseSubscription) |)
  SemaReply (| SemaReply (EntryWritten EntryWritten) (EntriesRead EntriesRead) (SubscriptionOpened SubscriptionOpened) (SubscriptionClosed SubscriptionClosed) |)
  AdminRequest (| AdminRequest Drain Pause Resume (Snapshot Snapshot) |)
  AdminReply (| AdminReply Drained Paused Resumed (SnapshotReady SnapshotReady) |)
  RuntimeEvent (| RuntimeEvent (MailSent MailSent) (MessageAccepted MessageAccepted) (MessageCommitted MessageCommitted) (MessageFailed MessageFailed) |)
  Rejected {| Rejected rejectionReason RejectionReason |}
  RejectionReason (| RejectionReason Malformed Unauthorized Conflict Unsupported StaleVersion InternalError |)
  RecordIntent {| RecordIntent actorIdentifier ActorIdentifier entry Entry |}
  ObserveIntent {| ObserveIntent query Query |}
  SubscribeIntent {| SubscribeIntent query Query |}
  RecordAccepted {| RecordAccepted recordIdentifier RecordIdentifier commitSequence CommitSequence |}
  ObservationReturned {| ObservationReturned recordSet RecordSet |}
  SubscriptionStarted {| SubscriptionStarted subscriptionToken SubscriptionToken |}
  PushSignal {| PushSignal signalRequest SignalRequest |}
  PushSemaResult {| PushSemaResult semaReply SemaReply |}
  PushedToSema {| PushedToSema semaRequest SemaRequest |}
  MailResolved {| MailResolved signalReply SignalReply |}
  WriteEntry {| WriteEntry entry Entry |}
  ReadEntries {| ReadEntries query Query |}
  OpenSubscription {| OpenSubscription query Query |}
  CloseSubscription {| CloseSubscription subscriptionToken SubscriptionToken |}
  EntryWritten {| EntryWritten recordIdentifier RecordIdentifier commitSequence CommitSequence databaseDigest DatabaseDigest |}
  EntriesRead {| EntriesRead recordSet RecordSet databaseDigest DatabaseDigest |}
  SubscriptionOpened {| SubscriptionOpened subscriptionToken SubscriptionToken commitSequence CommitSequence |}
  SubscriptionClosed {| SubscriptionClosed subscriptionToken SubscriptionToken commitSequence CommitSequence |}
  Snapshot {| Snapshot socketPath SocketPath |}
  SnapshotReady {| SnapshotReady socketPath SocketPath databaseDigest DatabaseDigest |}
  MailSent {| MailSent signalRequest SignalRequest |}
  MessageAccepted {| MessageAccepted signalRequest SignalRequest |}
  MessageCommitted {| MessageCommitted commitSequence CommitSequence |}
  MessageFailed {| MessageFailed rejectionReason RejectionReason |}
  Entry {| Entry topics Topics kind Kind description Description magnitude Magnitude actorIdentifier ActorIdentifier |}
  Topic {| Topic string String |}
  Topics {| Topics values (Vec Topic) |}
  Description {| Description string String |}
  Kind (| Kind Decision Principle Correction Clarification Constraint Observation Question |)
  Magnitude (| Magnitude Minimum VeryLow Low Medium High VeryHigh Maximum |)
  Query {| Query topics Topics kinds (Vec Kind) limit (Optional Integer) |}
  RecordIdentifier {| RecordIdentifier integer Integer |}
  SubscriptionToken {| SubscriptionToken integer Integer |}
  RecordSet {| RecordSet records (Vec Entry) byTopic (Map (Topic RecordIdentifier)) |}
}
