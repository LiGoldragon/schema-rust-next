{ DatabaseMarker marker-core:mail:DatabaseMarker
  CommitSequence marker-core:mail:CommitSequence }
[(Record Entry)
 (Observe Query)
 (Mark DatabaseMarker)
 (Commit CommitSequence)]
[(Recorded RecordReceipt)
 (Observed RecordSet)
 (Marked DatabaseMarker)
 (Committed CommitSequence)
 (Rejected Rejection)]
{
  Topic String
  Topics (Vector Topic)
  Description String
  AgentName String
  RecordIdentifier Integer
  Rejection Description
  Entry { Topics * description Description agentName AgentName databaseMarker DatabaseMarker }
  Query { Topics * limit (Optional Integer) }
  RecordReceipt { RecordIdentifier * databaseMarker DatabaseMarker commitSequence CommitSequence }
  RecordSet { records (Vector Entry) byTopic (Map Topic RecordIdentifier) }
}
