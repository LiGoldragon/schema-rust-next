[(Record Entry)
 (Correct Correction)
 (Observe Query)
 (Watch WatchRequest)
 (Unwatch SubscriptionToken)
 Reindex
 Compact]
[(Recorded RecordReceipt)
 (Corrected CorrectionReceipt)
 (Observed RecordSet)
 (Watching SubscriptionReceipt)
 (Unwatched SubscriptionReceipt)
 (Rejected Rejection)
 (Indexed IndexReceipt)]
{
  Topic String
  Topics (Vec Topic)
  Description String
  AgentName String
  Timestamp Integer
  RecordIdentifier Integer
  SubscriptionToken Integer
  CommitSequence Integer
  DatabaseDigest Integer
  Magnitude [Minimum VeryLow Low Medium High VeryHigh Maximum]
  Kind [Decision Principle Correction Clarification Constraint Observation Question]
  RejectionReason [Malformed Unauthorized Conflict Unsupported StaleVersion]
  Entry { Topics * kind Kind description Description magnitude Magnitude agentName AgentName timestamp Timestamp }
  Correction { RecordIdentifier * description Description magnitude Magnitude agentName AgentName timestamp Timestamp }
  Query { Topics * kinds (Vec Kind) limit (Optional Integer) }
  WatchRequest { Topics * kinds (Vec Kind) agentName AgentName }
  RecordReceipt { RecordIdentifier * commitSequence CommitSequence databaseDigest DatabaseDigest }
  CorrectionReceipt { RecordIdentifier * commitSequence CommitSequence databaseDigest DatabaseDigest }
  RecordSet { records (Vec Entry) byTopic (Map (Topic RecordIdentifier)) }
  SubscriptionReceipt { SubscriptionToken * commitSequence CommitSequence }
  Rejection { RejectionReason * description Description }
  IndexReceipt { CommitSequence * databaseDigest DatabaseDigest }
}
