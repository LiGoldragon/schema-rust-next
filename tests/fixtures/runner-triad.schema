{}
[(Record Entry) (Observe Query)]
[(RecordAccepted SemaReceipt) (RecordsStashed StashResult) (Error ErrorReport)]
{
  NexusWork [(SignalArrived Input) (SemaWriteCompleted SemaWriteOutput) (SemaReadCompleted SemaReadOutput) (EffectCompleted NexusEffectResult)]
  NexusAction [(CommandSemaWrite SemaWriteInput) (CommandSemaRead SemaReadInput) (ReplyToSignal Output) (CommandEffect NexusEffectCommand) (Continue NexusWork)]
  NexusEffectCommand [(Stash StashRequest)]
  NexusEffectResult [(Stashed StashResult)]
  SemaWriteInput [(Record Entry)]
  SemaReadInput [(Observe Query)]
  SemaWriteOutput [(Recorded SemaReceipt) (Missed ErrorReport)]
  SemaReadOutput [(Observed ObservedRecords) (Missed ErrorReport)]
  Topic String
  Description String
  ErrorMessage String
  RecordIdentifier Integer
  CommitSequence Integer
  StateDigest Integer
  DatabaseMarker { CommitSequence * stateDigest StateDigest }
  SemaReceipt { RecordIdentifier * databaseMarker DatabaseMarker }
  ObservedRecords { RecordSet * databaseMarker DatabaseMarker }
  StashHandle Integer
  StashResult { StashHandle * recordCount Integer databaseMarker DatabaseMarker }
  StashRequest { RecordSet * databaseMarker DatabaseMarker }
  ErrorReport { ErrorMessage * databaseMarker DatabaseMarker }
  Entry { Topic * description Description }
  Query { Topic * }
  RecordSet (Vec Entry)
}
