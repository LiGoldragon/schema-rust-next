  ObservedRecords { RecordSet * databaseMarker DatabaseMarker }
  StashHandle Integer
  StashResult { StashHandle * recordCount Integer databaseMarker DatabaseMarker }
  StashRequest { RecordSet * databaseMarker DatabaseMarker }
  ErrorReport { ErrorMessage * databaseMarker DatabaseMarker }
