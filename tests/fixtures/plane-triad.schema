[(Record Entry) (Observe Query)]
[(RecordAccepted SemaReceipt) (RecordsObserved ObservedRecords) (Error ErrorReport)]
{
  NexusInput@[(Signal Input) (Sema SemaOutput)]
  NexusOutput@[(Sema SemaInput) (Signal Output)]
  SemaInput@[(Record Entry) (Observe Query)]
  SemaOutput@[(Recorded SemaReceipt) (Observed ObservedRecords) (Missed ErrorReport)]
  Topic@{ string@String }
  Description@{ string@String }
  ErrorMessage@{ string@String }
  RecordIdentifier@{ integer@Integer }
  CommitSequence@{ integer@Integer }
  StateDigest@{ integer@Integer }
  DatabaseMarker@{ commitSequence@CommitSequence stateDigest@StateDigest }
  SemaReceipt@{ recordIdentifier@RecordIdentifier databaseMarker@DatabaseMarker }
  ObservedRecords@{ recordSet@RecordSet databaseMarker@DatabaseMarker }
  ErrorReport@{ errorMessage@ErrorMessage databaseMarker@DatabaseMarker }
  Entry@{ topic@Topic kind@Kind description@Description magnitude@Magnitude }
  Query@{ topic@Topic kind@Kind }
  RecordSet@{ entries@(Vec Entry) }
  Kind@[Decision Principle Correction Clarification Constraint]
  Magnitude@[Minimum VeryLow Low Medium High VeryHigh Maximum]
}
