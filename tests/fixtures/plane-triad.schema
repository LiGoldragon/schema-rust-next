((Record Entry) (Observe Query))
((RecordAccepted SemaReceipt) (RecordsObserved ObservedRecords) (Error ErrorReport))
{
  NexusInput (| NexusInput (Signal Input) (Sema SemaOutput) |)
  NexusOutput (| NexusOutput (Sema SemaInput) (Signal Output) |)
  SemaInput (| SemaInput (Record Entry) (Observe Query) |)
  SemaOutput (| SemaOutput (Recorded SemaReceipt) (Observed ObservedRecords) (Missed ErrorReport) |)
  Topic {| Topic string String |}
  Description {| Description string String |}
  ErrorMessage {| ErrorMessage string String |}
  RecordIdentifier {| RecordIdentifier integer Integer |}
  CommitSequence {| CommitSequence integer Integer |}
  StateDigest {| StateDigest integer Integer |}
  DatabaseMarker {| DatabaseMarker commitSequence CommitSequence stateDigest StateDigest |}
  SemaReceipt {| SemaReceipt recordIdentifier RecordIdentifier databaseMarker DatabaseMarker |}
  ObservedRecords {| ObservedRecords recordSet RecordSet databaseMarker DatabaseMarker |}
  ErrorReport {| ErrorReport errorMessage ErrorMessage databaseMarker DatabaseMarker |}
  Entry {| Entry topic Topic kind Kind description Description magnitude Magnitude |}
  Query {| Query topic Topic kind Kind |}
  RecordSet {| RecordSet entries (Vec Entry) |}
  Kind (| Kind Decision Principle Correction Clarification Constraint |)
  Magnitude (| Magnitude Minimum VeryLow Low Medium High VeryHigh Maximum |)
}
