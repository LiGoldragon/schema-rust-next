[(Record Entry) (Observe Query)]
[(RecordAccepted RecordIdentifier) (RecordsObserved RecordSet)]
{
  Topic String
  Description String
  RecordIdentifier Integer
  Entry { topic Topic description Description }
  Observation { note Description }
  Query { Topic * }
  RecordSet (Vec Entry)
  EntryFamily (Family { record Entry table entries key Domain })
  ObservationFamily (Family { record Observation table observations key Identified })
}
